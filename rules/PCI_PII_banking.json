[
  {
    "rule_code": "PCI_PII_0001",
    "description": "Detection of Personally Identifiable Information (PII) related to payment",
    "mitigation": "PII must be minimized and protected under PCI DSS Requirement 3 and applicable data protection regulations (GDPR, CCPA). Anonymize or pseudonymize data in logs.",
    "patterns": [
      {
        "name": "US Social Security Number",
        "regex": "\\b(?!000|666|9\\d{2})\\d{3}[\\s\\-](?!00)\\d{2}[\\s\\-](?!0000)\\d{4}\\b",
        "confidence": "High",
        "validate_luhn": false
      },
      {
        "name": "US Bank Routing Number (ABA)",
        "regex": "\\b(?:0[0-9]|1[0-2]|2[1-9]|3[0-2]|6[1-9]|7[0-2]|80)[0-9]{7}\\b",
        "confidence": "Medium",
        "validate_luhn": false
      },
      {
        "name": "IBAN (International Bank Account Number)",
        "regex": "\\b[A-Z]{2}[0-9]{2}[A-Z0-9]{4}[0-9]{7}(?:[A-Z0-9]{0,16})\\b",
        "confidence": "High",
        "validate_luhn": false
      },
      {
        "name": "Card expiry date",
        "regex": "(?i)(?:exp(?:ir(?:y|ation))?|valid[_\\s]?thru)[\\s=:\"']*((0[1-9]|1[0-2])[/\\-]([0-9]{2}|[0-9]{4}))",
        "confidence": "Medium",
        "validate_luhn": false
      },
      {
        "name": "Cardholder name pattern",
        "regex": "(?i)(?:cardholder[_\\s]?name|name[_\\s]?on[_\\s]?card)[\\s=:\"']+([A-Za-z ]{4,40})",
        "confidence": "Medium",
        "validate_luhn": false
      }
    ]
  },
  {
    "rule_code": "PCI_PII_0002",
